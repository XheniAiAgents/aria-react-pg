# ── ARIA v4 · Environment Variables ──────────────────────────────────────────
# LOCAL: copy this to .env and fill in your values.
# RAILWAY: add these in Railway dashboard → Variables tab.
# Never commit .env to git.

# Groq API — free at groq.com (AI chat and email summaries)
GROQ_API_KEY=your_groq_api_key_here

# Resend API — free at resend.com (welcome and password reset emails)
RESEND_API_KEY=your_resend_api_key_here

# Telegram Bot — optional, from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google OAuth — from console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# App URL
# Local:   http://127.0.0.1:8000
# Railway: https://your-app-name.up.railway.app
APP_URL=http://127.0.0.1:8000

# CORS origins — leave * for now
ALLOWED_ORIGINS=*

# Database path
# Local:   leave empty (uses backend/aria.db automatically)
# Railway: /data/aria.db  (after you create a volume mounted at /data)
# DB_PATH=/data/aria.db
